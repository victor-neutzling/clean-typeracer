{
  "manifest_version": 3,
  "name": "Clean Typeracer",
  "version": "1.0",
  "description": "Gives the typing game Typeracer a cleaner, higher contrast look to improve concentration during the races.",
  "permissions": ["scripting"],
  "browser_specific_settings": {
    "gecko": {
      "id": "clean-typeracer@victorneutzling"
    }
  }
  "content_scripts": [
    {
      "matches": ["*://*.typeracer.com/*"],
      "css": ["styles.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
